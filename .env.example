# Copy to .env (git-ignored) for local dev, or set these as host secrets in prod.

# Postgres connection string (Neon). Required at runtime AND for migrations/seed.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# NextAuth v5 JWT signing secret. Generate one:  openssl rand -base64 32
AUTH_SECRET="change-me"

# Public origin of the app. In prod = your https URL (e.g. https://fantasy-pl.fly.dev).
# Also used as the Socket.io CORS origin.
NEXTAUTH_URL="http://localhost:3000"

# Bearer token guarding the data-sync endpoints (/api/sync/*, waiver processing).
CRON_SECRET="change-me"

# Origin the browser uses for the draft websocket. Same as the app origin.
# IMPORTANT: NEXT_PUBLIC_* is baked into the client bundle at BUILD time, so it
# must be set when you run `next build` (in Docker: pass as a --build-arg).
NEXT_PUBLIC_SOCKET_URL="http://localhost:3000"

# Optional: server port (defaults to 3000).
# PORT=3000
